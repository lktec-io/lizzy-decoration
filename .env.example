# A relative path works in both dev (Vite's dev-server proxy, see
# vite.config.js) and production (Nginx reverse-proxies /api on the same
# origin, see deploy/nginx.conf.template) — same-origin keeps the httpOnly
# refresh-token cookie working without SameSite=None+Secure. Only override
# with an absolute URL (e.g. in .env.production) if the frontend and API
# are ever served from different origins.
VITE_API_URL=/api/v1
