# Set to "production" on the real server; local dev keeps "development".
# When NODE_ENV=production, only FRONTEND_URL is allowed by CORS.
# When NODE_ENV is anything else, http://localhost:5173 is also allowed
# automatically (see backend/config/cors.js) — no separate dev URL needed.
NODE_ENV=development
PORT=4000

DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use two DIFFERENT values — never reuse the access secret as the refresh secret.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# https://jozzy.clixworks.co.tz in production; http://localhost:5173 for local dev.
FRONTEND_URL=http://localhost:5173

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@jozzy.clixworks.co.tz

# Primary storage for uploaded images (avatars, company logo, product
# images) — required in production. Leave blank in local dev to fall back
# to local-disk uploads automatically (see backend/config/cloudinary.js).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
